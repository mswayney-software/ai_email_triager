    {
      "parameters": {
        "jsCode": "const out = [];\n\nfor (const item of $input.all()) {\n  // The LLM's reply text lives here. Field name may vary — see note below.\n  let raw = item.json.text ?? item.json.response ?? \"\";\n\n  // Step 1: strip markdown fences and trim whitespace\n  let cleaned = raw.replace(/```json/gi, \"\").replace(/```/g, \"\").trim();\n\n  let parsed = null;\n  let review = false;\n  let reason = \"\";\n  let route = \"draft\";\n\n  // Step 2: try to parse — if it fails, flag instead of crash\n  try {\n    parsed = JSON.parse(cleaned);\n  } catch (e) {\n    review = true;\n    reason = \"Could not parse JSON\";\n  }\n\n  // Step 3: validate the shape (only if it parsed)\n  if (parsed) {\n    const okCategory = [\"billing\",\"support\",\"sales\",\"spam\",\"personal\",\"other\"].includes(parsed.category);\n    const okConfidence = typeof parsed.confidence === \"number\";\n    const hasFields = parsed.urgency && parsed.suggested_action && parsed.intent_summary;\n\n    if (!okCategory || !okConfidence || !hasFields) {\n      review = true;\n      reason = \"Parsed but failed validation\";\n    }\n\n    // Business rule: low confidence always goes to a human\n    if (okConfidence && parsed.confidence < 0.7) {\n      review = true;\n      reason = \"Low confidence\";\n    }\n\n    // Business rule: sensitive categories always get human eyes, even at high confidence\n    if ([\"billing\", \"personal\"].includes(parsed.category)) {\n      review = true;\n      reason = reason ? reason + \" + sensitive category\" : \"Sensitive category\";\n    }\n\n    // Decide this email's fate: ignore, review, or draft\n                              // default: safe to auto-draft\n    if (parsed.safety_flag === true) {\n      route = \"review\";\n      reason = reason ? reason + \" + safety/privacy\" : \"Safety/privacy flag\";\n    } else if (parsed.category === \"spam\") {\n      route = \"ignore\";\n    } else if (review) {\n      route = \"review\";\n    }\n  }\n\n  out.push({\n    json: {\n      ...(parsed ?? {}),     // the classification fields, if we got them\n      needs_review: review,  // the flag your reasoning called for\n      review_reason: reason, // why it was flagged (great for your writeup)\n      raw_output: raw,        // keep the original, so nothing is ever lost\n      route: route,\n    }\n  });\n}\n\nreturn out;"
      },
